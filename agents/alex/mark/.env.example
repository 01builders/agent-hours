# =============================================================================
# Mark — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Email (IMAP) Settings ---
# For Gmail: use imap.gmail.com and an App Password
# For Outlook: use outlook.office365.com
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# --- Anthropic API ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database ---
# Default SQLite path (relative to project root)
DATABASE_PATH=data/mark.db

# --- Processing ---
# Max links to enrich per run (to control API costs)
MAX_LINKS_PER_RUN=30
# Delay between API calls in seconds (rate limiting)
API_CALL_DELAY=1.5
# Max age in days for emails to ingest on first run
INITIAL_INGEST_DAYS=30

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/mark.log
